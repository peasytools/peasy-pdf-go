# peasy-pdf-go — PDF merge, split, rotate, compress (Go)
# Theme: Dracula
# Generated for AgentGIF demo collection

Output demo.gif
Set Shell "zsh"
Set Theme "Dracula"
Set Width 800
Set Height 500
Set FontSize 14
Set Padding 20
Set TypingSpeed 50ms

# Show package info
Type "# peasy-pdf-go — PDF merge, split, rotate, compress for Go"
Enter
Type "# peasypdf.com"
Enter
Sleep 500ms

# Run the demo
Type "go run ./examples/demo/"
Enter
Sleep 5s
